rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }

    match /config/{document} {
      allow read: if true;
      allow write: if isSuperAdmin() || (request.auth != null && (document == 'payroll'));
      allow create, update: if request.auth != null && document == 'orderCounter';
    }
    match /products/{document} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /categories/{document} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /brands/{document} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /pages/{document} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /coupons/{document} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }
    match /reviews/{document} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'rating', 'comment', 'productId']) 
                     && request.resource.data.name is string 
                     && request.resource.data.rating is number 
                     && request.resource.data.comment is string;
      allow update, delete: if isSuperAdmin();
    }
    match /posts/{document} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    match /subscribers/{document} {
      allow read: if isSuperAdmin();
      allow create: if request.resource.data.keys().hasAll(['email']) && request.resource.data.email is string;
      allow update, delete: if isSuperAdmin();
    }
    match /customers/{document} {
      allow read: if isSuperAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin();
    }
    match /orders/{document} {
      allow read: if isSuperAdmin() || request.auth.token.email == resource.data.customerEmail;
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin();
    }
    match /users/{document} {
      allow read: if isSuperAdmin() || request.auth.uid == document;
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasOnly(["email", "displayName", "photoURL", "role", "isActive", "createdAt", "updatedAt"])
        && (
          request.resource.data.role == "lector"
          || request.auth.token.email == 'abrahanramos@gmail.com'
        );
      allow update: if isSuperAdmin() || request.auth.uid == document;
      allow delete: if isSuperAdmin();
    }
    match /inventory_movements/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if isSuperAdmin();
    }
    match /employees/{document} {
      allow read, write: if isSuperAdmin();
    }
    match /attendance_records/{document} {
      allow read, write: if isSuperAdmin();
    }
    match /payroll_periods/{document} {
      allow read, write: if isSuperAdmin();
    }
    match /loans/{document} {
      allow read, write: if isSuperAdmin();
    }
  }
}
