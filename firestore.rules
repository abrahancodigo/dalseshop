rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /products/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /categories/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /brands/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /pages/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /coupons/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /reviews/{document} {
      allow read: if true;
      allow write: if true;
    }
    match /posts/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
    }
    match /subscribers/{document} {
      allow read: if request.auth != null && request.auth.token.email == 'abrahanramos@gmail.com';
      allow write: if true;
    }
    match /orders/{document} {
      allow read, write: if true;
    }
  }
}
