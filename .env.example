# =====================================================
# Firebase config — YA NO se necesita crearlo manualmente.
# Los valores públicos (apiKey, projectId, etc.) están
# hardcodeados directamente en src/lib/firebase.jsx.
# =====================================================

# SMTP (para desarrollo local de Cloud Functions únicamente)
# En producción se usan Firebase Secrets:
#   firebase functions:secrets:set SMTP_USER
#   firebase functions:secrets:set SMTP_PASS
#   firebase functions:secrets:set SMTP_FROM
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=tu_email@gmail.com
